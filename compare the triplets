#include <stdio.h>
#include <stdlib.h>

/**
 * Note: The caller is responsible for freeing the returned memory.
 */
int* compareTriplets(int a_count, int* a, int b_count, int* b, int* result_count) {
    // We are always returning 2 values: [Alice's score, Bob's score]
    *result_count = 2;
    int* result = (int*)malloc(2 * sizeof(int));
    
    // Initialize scores to 0
    result[0] = 0; // Alice
    result[1] = 0; // Bob
    
    for (int i = 0; i < 3; i++) {
        if (a[i] > b[i]) {
            result[0]++;
        } else if (a[i] < b[i]) {
            result[1]++;
        }
    }
    
    return result;
}

int main() {
    int a[3], b[3];
    
    // Reading input
    if (scanf("%d %d %d", &a[0], &a[1], &a[2]) != 3) return 1;
    if (scanf("%d %d %d", &b[0], &b[1], &b[2]) != 3) return 1;
    
    int result_count;
    int* result = compareTriplets(3, a, 3, b, &result_count);
    
    // Printing output format expected by HackerRank
    printf("%d %d\n", result[0], result[1]);
    
    // Clean up
    free(result);
    
    return 0;
}
