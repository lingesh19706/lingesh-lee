#include <stdio.h>

void plusMinus(int arr_count, int* arr) {
    float pos = 0, neg = 0, zero = 0;

    for (int i = 0; i < arr_count; i++) {
        if (arr[i] > 0) {
            pos++;
        } else if (arr[i] < 0) {
            neg++;
        } else {
            zero++;
        }
    }

    // Print ratios with 6 decimal places
    printf("%.6f\n", pos / arr_count);
    printf("%.6f\n", neg / arr_count);
    printf("%.6f\n", zero / arr_count);
}

int main() {
    int n;
    scanf("%d", &n);

    int arr[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    plusMinus(n, arr);
    return 0;
}
