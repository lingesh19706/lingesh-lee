#include <stdio.h>
int ratsAndfood(int r,int unit,int arr[],int n)
{
  int totalfood=0;
  int requiredfood=r*unit;
  int i;
  if(arr==NULL)
  return-1;
  for(i=0;i<n;i++)
  {
    totalfood+=arr[i];
    if(totalfood>=requiredfood)
    return i+1;
  }
  return 0;
}
