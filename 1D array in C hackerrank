#include <stdio.h>
#include <stdlib.h>

int main() {
    int n;
    long long sum = 0; // Using long long to prevent overflow for large sums

    // 1. Read the size of the array
    if (scanf("%d", &n) != 1) return 0;

    // 2. Dynamically allocate memory for n integers
    // malloc returns a void pointer, so we cast it to (int*)
    int *arr = (int*)malloc(n * sizeof(int));

    // Check if memory allocation was successful
    if (arr == NULL) {
        return 1; 
    }

    // 3. Read values into the array
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // 4. Iterate through the array to calculate the sum
    for (int i = 0; i < n; i++) {
        sum += arr[i];
    }

    // 5. Print the result
    printf("%lld\n", sum);

    // 6. Free the allocated memory to prevent memory leaks
    free(arr);

    return 0;
}
