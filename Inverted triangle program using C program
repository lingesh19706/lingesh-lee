8. Inverted triangle program
#include <stdio.h>
int main()
{
  int rows,columns,i,j,h;
  printf("Enter the height :");
  scanf("%d",&h);
  for(i=1;i<=h;i++)
  {
      for(j=i;j<=h;j++)
      {
          printf("*");
      }
      printf("\n");
  }
      }
