
int marks_summation(int* marks, int number_of_students, char gender) {
    int sum = 0;
    int start_index;
    // Determine starting point: 0 for boys (even), 1 for girls (odd)
    if (gender == 'b') {
        start_index = 0;
    } else {
        start_index = 1;
    }
        for (int i = start_index; i < number_of_students; i += 2) {
        sum += marks[i];
    }
    return sum;
}

