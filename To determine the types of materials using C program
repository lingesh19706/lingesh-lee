5. Material types program
#include<stdio.h>
#include<stdlib.h>
int main()
{
  int ch;
  while(1)
  {
    printf("enter construction type code\n1-> residential building\n2-> commercial building\n3-> bridge construction\n4-> road construction\n5-> exit");
    scanf("%d",&ch);
    switch(ch)
    {
      case 1:
      printf("materials: brick & RCC\n");
      break;
      case 2:
      printf("materials: RCC & steel\n");
      break;
      case 3:
      printf("materials: prestressed concrete & steel\n");
      break;
      case 4:
      printf("materials: bitumen & concrete\n");
      break;
      case 5:
      exit(0);
      default:
      printf("enter a valid option\n");
    }
  }
  return 0;
}

