#include <stdio.h>

int main()
{
    int i1, i2;
    float f1, f2;
    
    // Read two integers
    scanf("%d %d", &i1, &i2);
    
    // Read two floats
    scanf("%f %f", &f1, &f2);
    
    // Print integer sum and difference
    // %d is for integers
    printf("%d %d\n", i1 + i2, i1 - i2);
    
    // Print float sum and difference
    // %.1f rounds the output to one decimal place
    printf("%.1f %.1f\n", f1 + f2, f1 - f2);
    
    return 0;
}
