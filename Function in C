#include <stdio.h>

/* 
   Function: max_of_four
   Returns the greatest of the four arguments provided.
*/
int max_of_four(int a, int b, int c, int d) {
    int max = a; // Assume 'a' is the largest initially

    if (b > max) {
        max = b;
    }
    if (c > max) {
        max = c;
    }
    if (d > max) {
        max = d;
    }
    
    return max;
}

int main() {
    int a, b, c, d;
    scanf("%d %d %d %d", &a, &b, &c, &d);
    int ans = max_of_four(a, b, c, d);
    printf("%d", ans);
    
    return 0;
}
