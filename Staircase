#include <stdio.h>

void staircase(int n) {
    for (int i = 1; i <= n; i++) {
        // Print spaces: (n - current_row_index)
        for (int j = 0; j < n - i; j++) {
            printf(" ");
        }
        
        // Print hashes: current_row_index
        for (int k = 0; k < i; k++) {
            printf("#");
        }
        
        // Move to the next line
        printf("\n");
    }
}

int main() {
    int n;
    if (scanf("%d", &n) == 1) {
        staircase(n);
    }
    return 0;
}
